{
  "$schema": "https://cdn.jsdelivr.net/npm/release-it@latest/schema/release-it.json",
  "git": {
    "push": true,
    "commitMessage": "chore(release): v${version}"
  },
  "github": {
    "release": true,
    "releaseNotes": "node .github/scripts/generate-release-notes.mjs"
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits"
    }
  }
}
